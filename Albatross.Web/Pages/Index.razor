@page "/"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Web
@inject HttpClient Http

<PageTitle>Albatross 뉴스</PageTitle>

<div class="app-container @(_darkMode ? "dark-mode" : "light-mode")">
    <div class="hero">
        <div class="header-top">
            <h1>🦅 Albatross News</h1>
            <div class="controls">
                <button class="theme-toggle" @onclick="() => _darkMode = !_darkMode">
                    @(_darkMode ? "🌞 Light" : "🌙 Dark")
                </button>
            </div>
        </div>
        <p class="subtitle">실시간 전 세계 주요 이슈 TOP 10</p>
    </div>

    <div class="content-area">
        @if (_loading)
        {
            <div class="loading">
                <div class="spinner"></div>
                <p>뉴스를 불러오는 중...</p>
            </div>
        }
        else if (_error is not null)
        {
            <div class="error-box">⚠️ @_error</div>
        }
        else if (_items is null || !_items.Any())
        {
            <div class="empty">수집된 뉴스가 없습니다. Collector를 먼저 실행해 주세요.</div>
        }
        else
        {
            <div class="news-grid">
                @foreach (var cluster in _topClusters)
                {
                    var item = cluster.MainItem;
                    var clusterId = item.Id;
                    var hasRelated = cluster.RelatedItems.Any();

                    <div class="news-cluster">
                        <div class="news-card-content" style="padding: 1.5rem;">
                            <div class="card-meta">
                                @{
                                    var allSources = new[] { cluster.MainItem.Source }.Concat(cluster.RelatedItems.Select(r => r.Source)).Distinct().ToList();
                                }
                                <span class="source-badge" style="background: #28a745;">
                                    @string.Join(", ", allSources.Take(2)) @(allSources.Count > 2 ? "외" : "") 보도
                                </span>
                                <span class="time">@FormatTime(item.PublishedAt)</span>
                            </div>
                            
                            <h4 style="margin-top: 1rem; font-size: 1.2rem; color: var(--text-color); font-weight: bold;">
                                @GenerateShortSummary(cluster)
                            </h4>
                        </div>

                        <button class="related-toggle" @onclick="() => ToggleRelated(clusterId)">
                            🔗 관련 기사 @(cluster.RelatedItems.Count + 1) 건 @(_expandedRelated.Contains(clusterId) ? "접기 ▲" : "목록 보기 ▼")
                        </button>
                        
                        @if (_expandedRelated.Contains(clusterId))
                        {
                            <div class="related-list">
                                <a href="@cluster.MainItem.Url" target="_blank" class="related-item">
                                    <span class="related-source">@cluster.MainItem.Source</span>
                                    <span class="related-title">@cluster.MainItem.Title</span>
                                </a>
                                @foreach (var related in cluster.RelatedItems)
                                {
                                    <a href="@related.Url" target="_blank" class="related-item">
                                        <span class="related-source">@related.Source</span>
                                        <span class="related-title">@related.Title</span>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    :root {
        --bg-color: #f8f9fa;
        --text-color: #333;
        --card-bg: white;
        --hero-bg: #fff;
        --border-color: #eee;
        --shadow: 0 4px 6px rgba(0,0,0,0.05);
        --accent: #007bff;
    }

    .dark-mode {
        --bg-color: #121212;
        --text-color: #e0e0e0;
        --card-bg: #1e1e1e;
        --hero-bg: #181818;
        --border-color: #333;
        --shadow: 0 4px 10px rgba(0,0,0,0.3);
    }

    .app-container { 
        min-height: 100vh; 
        background-color: var(--bg-color); 
        color: var(--text-color); 
        transition: background-color 0.3s, color 0.3s;
        padding-bottom: 3rem;
    }

    .hero { 
        background-color: var(--hero-bg); 
        padding: 2rem 5%; 
        border-bottom: 1px solid var(--border-color);
        margin-bottom: 2rem;
    }

    .header-top { display: flex; justify-content: space-between; align-items: center; }
    
    .theme-toggle {
        padding: 0.5rem 1rem;
        border-radius: 20px;
        border: 1px solid var(--border-color);
        background: var(--card-bg);
        color: var(--text-color);
        cursor: pointer;
        font-weight: bold;
    }

    .content-area { padding: 0 5%; }

    .news-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); 
        gap: 1.5rem; 
    }

    .news-cluster {
        display: flex;
        flex-direction: column;
        background: var(--card-bg);
        border-radius: 12px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border-color);
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .news-cluster:hover { transform: translateY(-5px); box-shadow: 0 8px 20px rgba(0,0,0,0.15); }

    .news-card-content {
        display: flex;
        flex-direction: column;
    }

    .related-toggle {
        background: rgba(0, 123, 255, 0.05);
        border: none;
        border-top: 1px solid var(--border-color);
        padding: 0.8rem;
        width: 100%;
        text-align: center;
        color: var(--accent);
        font-weight: bold;
        font-size: 0.85rem;
        cursor: pointer;
        transition: background 0.2s;
    }
    .related-toggle:hover { background: rgba(0, 123, 255, 0.1); }

    .related-list {
        display: flex;
        flex-direction: column;
        border-top: 1px solid var(--border-color);
        background: rgba(0,0,0,0.02);
    }
    .dark-mode .related-list { background: rgba(255,255,255,0.02); }

    .related-item {
        padding: 0.8rem 1.5rem;
        text-decoration: none;
        color: var(--text-color);
        font-size: 0.9rem;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        gap: 0.5rem;
        align-items: center;
        transition: background 0.2s;
    }
    .related-item:last-child { border-bottom: none; }
    .related-item:hover { background: rgba(0,0,0,0.05); }
    .dark-mode .related-item:hover { background: rgba(255,255,255,0.05); }

    .related-source {
        font-size: 0.7rem;
        background: #6c757d;
        color: white;
        padding: 2px 6px;
        border-radius: 4px;
        white-space: nowrap;
    }
    .related-title {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .card-meta { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; margin-bottom: 0.8rem; font-size: 0.75rem; opacity: 0.8; }
    .source-badge { background: var(--accent); color: white; padding: 2px 8px; border-radius: 4px; }
    .country-badge, .category-badge { border: 1px solid var(--border-color); padding: 2px 8px; border-radius: 4px; }

    .news-card h4 { font-size: 1.1rem; margin: 0.5rem 0; line-height: 1.4; font-weight: 600; }
    .summary { font-size: 0.9rem; color: var(--text-color); opacity: 0.7; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

    .loading, .empty, .error-box { text-align: center; padding: 4rem; font-size: 1.2rem; }
</style>

@code {
    private bool _darkMode = false;
    private HashSet<string> _expandedRelated = new();
    private bool _loading = true;
    private string? _error;
    private List<NewsDto>? _items;
    private List<NewsCluster> _topClusters = new();

    private void BuildTopClusters()
    {
        if (_items == null || !_items.Any()) return;

        _topClusters = GroupIntoClusters(_items)
            .OrderByDescending(c => c.RelatedItems.Count)
            .ThenByDescending(c => c.MainItem.PublishedAt)
            .Take(10)
            .ToList();
    }

    private void ToggleRelated(string clusterId)
    {
        if (_expandedRelated.Contains(clusterId))
            _expandedRelated.Remove(clusterId);
        else
            _expandedRelated.Add(clusterId);
    }

    // --- Clustering Logic ---
    private IEnumerable<NewsCluster> GroupIntoClusters(IEnumerable<NewsDto> items)
    {
        var clusters = new List<NewsCluster>();
        foreach (var item in items)
        {
            var matchedCluster = clusters.FirstOrDefault(c => IsSimilar(c.MainItem.Title, item.Title));
            if (matchedCluster != null)
            {
                matchedCluster.RelatedItems.Add(item);
            }
            else
            {
                clusters.Add(new NewsCluster(item, new List<NewsDto>()));
            }
        }
        return clusters;
    }

    private static readonly string[] StopWords = { "의", "는", "이", "가", "은", "를", "에", "대해", "그리고", "따라", "로", "과", "와", "다", "로", "에서", "부터", "까지", "에게" };

    private bool IsSimilar(string title1, string title2)
    {
        var words1 = GetSignificantWords(title1);
        var words2 = GetSignificantWords(title2);

        if (words1.Count == 0 || words2.Count == 0) return false;

        var intersection = words1.Intersect(words2).Count();
        var union = words1.Union(words2).Count();
        
        if (union == 0) return false;
        
        var similarity = (double)intersection / union;
        return similarity >= 0.25; // 25% 이상 단어가 겹치면 유사 기사로 판별
    }

    private HashSet<string> GetSignificantWords(string text)
    {
        return text.Split(new[] { ' ', ',', '.', '!', '?', '\'', '\"', '[', ']', '(', ')', ':', '-', '·', '‘', '’', '“', '”' }, StringSplitOptions.RemoveEmptyEntries)
                   .Where(w => w.Length > 1 && !StopWords.Contains(w))
                   .Select(w => w.ToLower())
                   .ToHashSet();
    }

    private string GenerateShortSummary(NewsCluster cluster)
    {
        var allTitles = new List<string> { cluster.MainItem.Title };
        allTitles.AddRange(cluster.RelatedItems.Select(x => x.Title));

        var wordCounts = allTitles
            .SelectMany(GetSignificantWords)
            .GroupBy(w => w)
            .OrderByDescending(g => g.Count())
            .Select(g => g.Key)
            .ToList();

        if (wordCounts.Count >= 2)
        {
            var summary = $"'{wordCounts[0]}·{wordCounts[1]}' 관련 주요 소식";
            return summary.Length > 20 ? summary.Substring(0, 18) + ".." : summary;
        }
        else if (wordCounts.Count == 1)
        {
            var summary = $"'{wordCounts[0]}' 관련 주요 소식";
            return summary.Length > 20 ? summary.Substring(0, 18) + ".." : summary;
        }
        
        var title = cluster.MainItem.Title;
        return title.Length > 20 ? title.Substring(0, 18) + ".." : title;
    }
    // ------------------------

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _items = await Http.GetFromJsonAsync<List<NewsDto>>("data/news.json");
        }
        catch (HttpRequestException)
        {
            _items = GetSampleData();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            BuildTopClusters();
            _loading = false;
        }
    }

    private List<NewsDto> GetSampleData() =>
    [
        new NewsDto("1", "한국 기술 혁신 소식", "한국의 IT 산업이 글로벌 시장에서 주목받고 있습니다.", "https://github.com", "Albatross", DateTimeOffset.Now, "IT", "한국"),
        new NewsDto("2", "미국 경제 지표 발표", "미국 연준의 금리 동결 소식에 증시가 반응하고 있습니다.", "https://github.com", "Albatross", DateTimeOffset.Now.AddMinutes(-10), "경제", "미국"),
        new NewsDto("3", "영국 스포츠 리그 결승", "프리미어리그 결승전에서 극적인 역전승이 나왔습니다.", "https://github.com", "Albatross", DateTimeOffset.Now.AddMinutes(-20), "스포츠", "영국"),
        new NewsDto("4", "중국 시장 경제 전망", "중국의 기술 수출 규모가 작년 대비 크게 성장했습니다.", "https://github.com", "Albatross", DateTimeOffset.Now.AddMinutes(-30), "경제", "중국")
    ];

    private static string FormatTime(DateTimeOffset dt)
    {
        var diff = DateTimeOffset.Now - dt;
        return diff.TotalMinutes < 60 ? $"{(int)diff.TotalMinutes}분 전" :
               diff.TotalHours < 24 ? $"{(int)diff.TotalHours}시간 전" :
               dt.ToString("MM/dd HH:mm");
    }

    private record NewsDto(
        string Id,
        string Title,
        string Summary,
        string Url,
        string Source,
        DateTimeOffset PublishedAt,
        string Category,
        string Country);

    private record NewsCluster(
        NewsDto MainItem,
        List<NewsDto> RelatedItems);
}
