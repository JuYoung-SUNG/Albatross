@page "/"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Web
@inject HttpClient Http

<PageTitle>Albatross 뉴스</PageTitle>

<div class="app-container @(_darkMode ? "dark-mode" : "light-mode")">
    <div class="hero">
        <div class="header-top">
            <h1>🦅 Albatross News</h1>
            <div class="controls">
                <button class="theme-toggle" @onclick="() => _darkMode = !_darkMode">
                    @(_darkMode ? "🌞 Light" : "🌙 Dark")
                </button>
            </div>
        </div>
        <p class="subtitle">전 세계의 최신 뉴스를 한눈에</p>
        
        <div class="filter-tabs">
            <button class="@(_filterType == FilterType.Category ? "active" : "")" @onclick="() => SetFilter(FilterType.Category)">분야별 보기</button>
            <button class="@(_filterType == FilterType.Country ? "active" : "")" @onclick="() => SetFilter(FilterType.Country)">국가별 보기</button>
        </div>
    </div>

    <div class="content-area">
        @if (_loading)
        {
            <div class="loading">
                <div class="spinner"></div>
                <p>뉴스를 불러오는 중...</p>
            </div>
        }
        else if (_error is not null)
        {
            <div class="error-box">⚠️ @_error</div>
        }
        else if (_items is null || !_items.Any())
        {
            <div class="empty">수집된 뉴스가 없습니다. Collector를 먼저 실행해 주세요.</div>
        }
        else
        {
            <div class="news-sections">
                @foreach (var group in GroupedItems)
                {
                    <section class="category-section">
                        <h2 class="category-title" @onclick="() => ToggleSection(group.Key)" style="cursor:pointer; display:flex; justify-content:space-between; align-items:center;">
                            <span>@group.Key</span>
                            <span style="font-size: 1rem; color: var(--accent);">@(_expandedSections.Contains(group.Key) ? "▼" : "▶")</span>
                        </h2>
                        @if (_expandedSections.Contains(group.Key))
                        {
                            var secondaryType = _filterType == FilterType.Category ? FilterType.Country : FilterType.Category;
                            var subGroups = group.GroupBy(i => secondaryType == FilterType.Category ? i.Category : i.Country)
                                                 .OrderBy(g => GetOrder(g.Key, secondaryType));

                            foreach (var subGroup in subGroups)
                            {
                                var subKey = $"{group.Key}:{subGroup.Key}";
                                <h3 class="subcategory-title" @onclick="() => ToggleSubSection(subKey)" style="cursor:pointer; display:flex; justify-content:space-between; align-items:center;">
                                    <span>@subGroup.Key</span>
                                    <span style="font-size: 0.9rem; color: var(--accent); opacity: 0.8;">@(_expandedSubSections.Contains(subKey) ? "▼" : "▶")</span>
                                </h3>
                                
                                @if (_expandedSubSections.Contains(subKey))
                                {
                                    <div class="news-grid">
                                    @foreach (var cluster in GroupIntoClusters(subGroup))
                                    {
                                        var item = cluster.MainItem;
                                        var clusterId = item.Id;
                                        var hasRelated = cluster.RelatedItems.Any();

                                        <div class="news-cluster">
                                            <a class="news-card" href="@item.Url" target="_blank" rel="noopener noreferrer">
                                                <div class="card-meta">
                                                    <span class="source-badge">@item.Source</span>
                                                    <span class="time">@FormatTime(item.PublishedAt)</span>
                                                </div>
                                                <h4>@item.Title</h4>
                                                <p class="summary">@item.Summary</p>
                                            </a>

                                            @if (hasRelated)
                                            {
                                                <button class="related-toggle" @onclick="() => ToggleRelated(clusterId)">
                                                    🔗 유사 기사 @cluster.RelatedItems.Count 건 @(_expandedRelated.Contains(clusterId) ? "접기 ▲" : "더보기 ▼")
                                                </button>
                                                @if (_expandedRelated.Contains(clusterId))
                                                {
                                                    <div class="related-list">
                                                        @foreach (var related in cluster.RelatedItems)
                                                        {
                                                            <a href="@related.Url" target="_blank" class="related-item">
                                                                <span class="related-source">@related.Source</span>
                                                                <span class="related-title">@related.Title</span>
                                                            </a>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                                }
                            }
                        }
                    </section>
                }
            </div>
        }
    </div>
</div>

<style>
    :root {
        --bg-color: #f8f9fa;
        --text-color: #333;
        --card-bg: white;
        --hero-bg: #fff;
        --border-color: #eee;
        --shadow: 0 4px 6px rgba(0,0,0,0.05);
        --accent: #007bff;
    }

    .dark-mode {
        --bg-color: #121212;
        --text-color: #e0e0e0;
        --card-bg: #1e1e1e;
        --hero-bg: #181818;
        --border-color: #333;
        --shadow: 0 4px 10px rgba(0,0,0,0.3);
    }

    .app-container { 
        min-height: 100vh; 
        background-color: var(--bg-color); 
        color: var(--text-color); 
        transition: background-color 0.3s, color 0.3s;
        padding-bottom: 3rem;
    }

    .hero { 
        background-color: var(--hero-bg); 
        padding: 2rem 5%; 
        border-bottom: 1px solid var(--border-color);
        margin-bottom: 2rem;
    }

    .header-top { display: flex; justify-content: space-between; align-items: center; }
    
    .theme-toggle {
        padding: 0.5rem 1rem;
        border-radius: 20px;
        border: 1px solid var(--border-color);
        background: var(--card-bg);
        color: var(--text-color);
        cursor: pointer;
        font-weight: bold;
    }

    .filter-tabs { display: flex; gap: 1rem; margin-top: 1.5rem; }
    .filter-tabs button {
        padding: 0.5rem 1.5rem;
        border: none;
        background: transparent;
        color: var(--text-color);
        cursor: pointer;
        font-weight: bold;
        border-bottom: 3px solid transparent;
        transition: all 0.2s;
        opacity: 0.7;
    }
    .filter-tabs button.active {
        opacity: 1;
        border-bottom-color: var(--accent);
        color: var(--accent);
    }

    .content-area { padding: 0 5%; }

    .category-section { margin-bottom: 3rem; }
    .category-title { 
        font-size: 1.5rem; 
        border-left: 5px solid var(--accent); 
        padding-left: 1rem; 
        margin-bottom: 1.5rem;
        color: var(--text-color);
    }

    .subcategory-title {
        font-size: 1.2rem;
        margin-top: 1.5rem;
        margin-bottom: 1rem;
        color: var(--text-color);
        opacity: 0.9;
        padding-left: 0.5rem;
        border-left: 3px solid var(--border-color);
    }

    .news-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); 
        gap: 1.5rem; 
    }

    .news-cluster {
        display: flex;
        flex-direction: column;
        background: var(--card-bg);
        border-radius: 12px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border-color);
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .news-cluster:hover { transform: translateY(-5px); box-shadow: 0 8px 20px rgba(0,0,0,0.15); }

    .news-card {
        display: flex;
        flex-direction: column;
        padding: 1.5rem;
        text-decoration: none;
        color: inherit;
    }

    .related-toggle {
        background: rgba(0, 123, 255, 0.05);
        border: none;
        border-top: 1px solid var(--border-color);
        padding: 0.8rem;
        width: 100%;
        text-align: center;
        color: var(--accent);
        font-weight: bold;
        font-size: 0.85rem;
        cursor: pointer;
        transition: background 0.2s;
    }
    .related-toggle:hover { background: rgba(0, 123, 255, 0.1); }

    .related-list {
        display: flex;
        flex-direction: column;
        border-top: 1px solid var(--border-color);
        background: rgba(0,0,0,0.02);
    }
    .dark-mode .related-list { background: rgba(255,255,255,0.02); }

    .related-item {
        padding: 0.8rem 1.5rem;
        text-decoration: none;
        color: var(--text-color);
        font-size: 0.9rem;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        gap: 0.5rem;
        align-items: center;
        transition: background 0.2s;
    }
    .related-item:last-child { border-bottom: none; }
    .related-item:hover { background: rgba(0,0,0,0.05); }
    .dark-mode .related-item:hover { background: rgba(255,255,255,0.05); }

    .related-source {
        font-size: 0.7rem;
        background: #6c757d;
        color: white;
        padding: 2px 6px;
        border-radius: 4px;
        white-space: nowrap;
    }
    .related-title {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .card-meta { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; margin-bottom: 0.8rem; font-size: 0.75rem; opacity: 0.8; }
    .source-badge { background: var(--accent); color: white; padding: 2px 8px; border-radius: 4px; }
    .country-badge, .category-badge { border: 1px solid var(--border-color); padding: 2px 8px; border-radius: 4px; }

    .news-card h4 { font-size: 1.1rem; margin: 0.5rem 0; line-height: 1.4; font-weight: 600; }
    .summary { font-size: 0.9rem; color: var(--text-color); opacity: 0.7; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

    .loading, .empty, .error-box { text-align: center; padding: 4rem; font-size: 1.2rem; }
</style>

@code {
    private enum FilterType { Category, Country }
    private FilterType _filterType = FilterType.Category;
    private bool _darkMode = false;
    private HashSet<string> _expandedSections = new();
    private HashSet<string> _expandedSubSections = new();
    private HashSet<string> _expandedRelated = new();
    private bool _loading = true;
    private string? _error;
    private List<NewsDto>? _items;

    private IEnumerable<IGrouping<string, NewsDto>> GroupedItems => 
        (_items ?? Enumerable.Empty<NewsDto>())
        .GroupBy(i => _filterType == FilterType.Category ? i.Category : i.Country)
        .OrderBy(g => GetOrder(g.Key, _filterType));

    private int GetOrder(string key, FilterType type)
    {
        if (type == FilterType.Category)
            return key switch { "정치" => 0, "경제" => 1, "사회" => 2, "IT" => 3, "일반" => 4, "스포츠" => 5, _ => 6 };
        else
            return key switch { "한국" => 0, "미국" => 1, "영국" => 2, "중국" => 3, _ => 4 };
    }

    private void SetFilter(FilterType type)
    {
        _filterType = type;
        _expandedSections.Clear();
        _expandedSubSections.Clear();
    }

    private void ToggleSection(string key)
    {
        if (_expandedSections.Contains(key))
            _expandedSections.Remove(key);
        else
            _expandedSections.Add(key);
    }

    private void ToggleSubSection(string subKey)
    {
        if (_expandedSubSections.Contains(subKey))
            _expandedSubSections.Remove(subKey);
        else
            _expandedSubSections.Add(subKey);
    }

    private void ToggleRelated(string clusterId)
    {
        if (_expandedRelated.Contains(clusterId))
            _expandedRelated.Remove(clusterId);
        else
            _expandedRelated.Add(clusterId);
    }

    // --- Clustering Logic ---
    private IEnumerable<NewsCluster> GroupIntoClusters(IEnumerable<NewsDto> items)
    {
        var clusters = new List<NewsCluster>();
        foreach (var item in items)
        {
            var matchedCluster = clusters.FirstOrDefault(c => IsSimilar(c.MainItem.Title, item.Title));
            if (matchedCluster != null)
            {
                matchedCluster.RelatedItems.Add(item);
            }
            else
            {
                clusters.Add(new NewsCluster(item, new List<NewsDto>()));
            }
        }
        return clusters;
    }

    private static readonly string[] StopWords = { "의", "는", "이", "가", "은", "를", "에", "대해", "그리고", "따라", "로", "과", "와", "다", "로", "에서", "부터", "까지", "에게" };

    private bool IsSimilar(string title1, string title2)
    {
        var words1 = GetSignificantWords(title1);
        var words2 = GetSignificantWords(title2);

        if (words1.Count == 0 || words2.Count == 0) return false;

        var intersection = words1.Intersect(words2).Count();
        var union = words1.Union(words2).Count();
        
        if (union == 0) return false;
        
        var similarity = (double)intersection / union;
        return similarity >= 0.25; // 25% 이상 단어가 겹치면 유사 기사로 판별
    }

    private HashSet<string> GetSignificantWords(string text)
    {
        return text.Split(new[] { ' ', ',', '.', '!', '?', '\'', '\"', '[', ']', '(', ')', ':', '-', '·', '‘', '’', '“', '”' }, StringSplitOptions.RemoveEmptyEntries)
                   .Where(w => w.Length > 1 && !StopWords.Contains(w))
                   .Select(w => w.ToLower())
                   .ToHashSet();
    }
    // ------------------------

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _items = await Http.GetFromJsonAsync<List<NewsDto>>("data/news.json");
        }
        catch (HttpRequestException)
        {
            _items = GetSampleData();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private List<NewsDto> GetSampleData() =>
    [
        new NewsDto("1", "한국 기술 혁신 소식", "한국의 IT 산업이 글로벌 시장에서 주목받고 있습니다.", "https://github.com", "Albatross", DateTimeOffset.Now, "IT", "한국"),
        new NewsDto("2", "미국 경제 지표 발표", "미국 연준의 금리 동결 소식에 증시가 반응하고 있습니다.", "https://github.com", "Albatross", DateTimeOffset.Now.AddMinutes(-10), "경제", "미국"),
        new NewsDto("3", "영국 스포츠 리그 결승", "프리미어리그 결승전에서 극적인 역전승이 나왔습니다.", "https://github.com", "Albatross", DateTimeOffset.Now.AddMinutes(-20), "스포츠", "영국"),
        new NewsDto("4", "중국 시장 경제 전망", "중국의 기술 수출 규모가 작년 대비 크게 성장했습니다.", "https://github.com", "Albatross", DateTimeOffset.Now.AddMinutes(-30), "경제", "중국")
    ];

    private static string FormatTime(DateTimeOffset dt)
    {
        var diff = DateTimeOffset.Now - dt;
        return diff.TotalMinutes < 60 ? $"{(int)diff.TotalMinutes}분 전" :
               diff.TotalHours < 24 ? $"{(int)diff.TotalHours}시간 전" :
               dt.ToString("MM/dd HH:mm");
    }

    private record NewsDto(
        string Id,
        string Title,
        string Summary,
        string Url,
        string Source,
        DateTimeOffset PublishedAt,
        string Category,
        string Country);

    private record NewsCluster(
        NewsDto MainItem,
        List<NewsDto> RelatedItems);
}
