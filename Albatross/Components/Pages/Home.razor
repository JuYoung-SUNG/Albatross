@page "/"
@inject System.Net.Http.HttpClient Http

<h1>Latest News</h1>

<button class="btn" @onclick="Refresh">Refresh</button>

@if (news is null)
{
    <p>Loading...</p>
}
else if (!news.Any())
{
    <p>No news available.</p>
}
else
{
    <ul>
        @foreach (var item in news)
        {
            <li>
                <h3>@item.Title</h3>
                <p>@item.Summary</p>
                <a href="@item.Url" target="_blank">Read more</a>
                <br />
                <small>@item.PublishedAt.ToLocalTime().ToString("g") - @item.Source</small>
            </li>
        }
    </ul>
}

@code {
    private IEnumerable<Albatross.Shared.Models.NewsItem>? news;

    protected override async Task OnInitializedAsync()
    {
        await LoadNews();
    }

    private async Task LoadNews()
    {
        try
        {
            // Placeholder endpoint - replace with actual API endpoint later
            news = await Http.GetFromJsonAsync<IEnumerable<Albatross.Shared.Models.NewsItem>>("/api/news/latest");
        }
        catch
        {
            news = Array.Empty<Albatross.Shared.Models.NewsItem>();
        }
    }

    private async Task Refresh()
    {
        await LoadNews();
    }
}
